{
  "name": "revbridge-desktop",
  "version": "0.1.0-alpha.1",
  "description": "A friendly desktop GUI for Android USB reverse tethering.",
  "author": "Innocent Cheng'ole Were",
  "license": "Apache-2.0",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "esbuild src/main/main.ts src/main/preload.ts --bundle --platform=node --target=node22 --format=cjs --outdir=dist/main --external:electron --external:usb --sourcemap",
    "build:renderer": "vite build",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "io.github.innocent254.revbridge.desktop",
    "productName": "RevBridge",
    "asar": true,
    "buildDependenciesFromSource": true,
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/@node-usb/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/staged",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../NOTICE",
        "to": "NOTICE.txt"
      },
      {
        "from": "../LICENSE",
        "to": "LICENSE.txt"
      },
      {
        "from": "../THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.txt"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "RevBridge-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "artifactName": "RevBridge-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "artifactName": "RevBridge-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-daemon-webusb": "^2.3.2",
    "@yume-chan/android-bin": "^2.1.0",
    "@yume-chan/stream-extra": "^2.6.1",
    "usb": "^3.0.1"
  }
}
